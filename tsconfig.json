{
  "compilerOptions": {
    "lib": [
      "es2019",
      "esnext.asynciterable",
    ],
    "target": "es2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./build",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "pretty": true,
    "strict": true
  },
  "include": [
    "src/**/*.ts",
  ],
}
