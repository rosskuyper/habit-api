# enables gql playground and prevents bugsnag reporting
NODE_ENV=local

# required even in local to ensure libs load as expected
BUGSNAG_API_KEY=

# the main ddb table
DDB_HABITS_TABLE=
DDB_AUTH_TABLE=

AWS_SDK_LOAD_CONFIG=1

AUTH_COGNITO_CLIENT_ID=
AUTH_COGNITO_CLIENT_SECRET=
AUTH_COGNITO_AUTHORIZE_URI=
AUTH_COGNITO_REDIRECT_URI=
