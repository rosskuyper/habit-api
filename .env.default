# enables gql playground and prevents bugsnag reporting
NODE_ENV=local
OUTPUT_ERRORS_TO_CONSOLE=true
PLAYGROUND_ENABLED=true

# required even in local to ensure libs load as expected
BUGSNAG_API_KEY=

# the main ddb table
DDB_PRIMARY_TABLE=habit-api-primary

AWS_SDK_LOAD_CONFIG=1

CORS_ALLOWED_ORIGINS=http://localhost:9000,http://localhost:3000

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
